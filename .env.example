# docker-compose (raiz) — copie para .env e ajuste se quiser
POSTGRES_USER=orderhub
POSTGRES_PASSWORD=orderhub
POSTGRES_DB=orderhub

# URL pública da API usada pelo front (build do web)
VITE_API_URL=http://localhost:3000/api
# origens permitidas no CORS da API
CORS_ORIGIN=http://localhost:8080

# porta do Postgres no host (evita conflito com outros projetos)
DB_PORT=5434
